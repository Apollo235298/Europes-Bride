# Copy to .env.local and fill in from your Supabase project (Settings → API).
# Leave unset to run in demo mode (mock data, simulated login).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used by `npm run seed` to create users and seed data. Never expose client-side.
SUPABASE_SERVICE_ROLE_KEY=
SEED_ADMIN_EMAIL=j.moon@ranklocalnow.com
SEED_ADMIN_PASSWORD=
SEED_CLIENT_EMAIL=ivan@europesbride.com
SEED_CLIENT_PASSWORD=
